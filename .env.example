# Application
PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/clinic_dashboard?retryWrites=true&w=majority
TEST_MONGODB_URI=mongodb://127.0.0.1:27017/clinic_dashboard_test
SESSION_SECRET=replace-with-at-least-32-random-characters

# Initial administrator (used only by npm run seed:admin)
ADMIN_NAME=Clinic Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ReplaceWithAStrongPassword!123

# Hot Prospector backend credentials
HOT_PROSPECTOR_API_UID=
HOT_PROSPECTOR_API_KEY=
HOT_PROSPECTOR_BASE_URL=https://service.hookscall.com/glu/api/v2
HOT_PROSPECTOR_TIMEOUT_MS=15000
HOT_PROSPECTOR_RETRIES=3
HOT_PROSPECTOR_METHOD_LEADS=SearchByUserInput
HOT_PROSPECTOR_METHOD_APPOINTMENTS=FetchAppointments

# Optional authoritative web-dashboard session. Treat this as a secret and rotate it when expired.
HOT_PROSPECTOR_WEB_COOKIE=

# Synchronization schedules
SYNC_CRON_ENABLED=true
SYNC_CRON_RECENT=*/5 * * * *
SYNC_CRON_METRICS=0 * * * *
SYNC_CRON_NIGHTLY=15 2 * * *
SYNC_CRON_RECALCULATE=45 2 * * *
SYNC_CRON_TIMEZONE=UTC
CRON_LOCK_TTL_MS=7200000

# Metrics
METRICS_MAX_RANGE_DAYS=366
METRICS_DEFAULT_RANGE_DAYS=30
METRICS_VALID_BOOKING_STATUSES=booked,confirmed,scheduled
METRICS_EXCLUDED_BOOKING_STATUSES=cancelled,deleted,no-show
METRICS_CRON_DAILY=10 3 * * *
METRICS_CACHE_TTL_MS=30000

# Security and reliability
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
REQUEST_TIMEOUT_MS=120000
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=1
