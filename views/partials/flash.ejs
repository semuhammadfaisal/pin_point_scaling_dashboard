<% if (flash) { %>
  <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show app-alert" role="alert">
    <i class="bi <%= flash.type === 'error' ? 'bi-exclamation-circle-fill' : 'bi-check-circle-fill' %> me-2" aria-hidden="true"></i>
    <%= flash.message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>
