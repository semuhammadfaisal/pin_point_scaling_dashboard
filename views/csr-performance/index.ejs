<%- include('../partials/filter-bar') %>
<div class="dashboard-alert d-none" data-page-alert role="alert"></div>
<section class="report-card table-report-card">
  <div class="table-toolbar"><div><h2>CSR performance</h2><p>Activity, conversion, and time efficiency by team member.</p></div><div class="table-tools"><label class="search-control"><span class="visually-hidden">Search CSRs</span><i class="bi bi-search"></i><input class="form-control" type="search" placeholder="Search CSRs" data-table-search></label><button class="btn btn-outline-secondary" type="button" data-export><i class="bi bi-download me-2"></i>Export CSV</button></div></div>
  <div class="table-responsive"><table class="table dashboard-table align-middle"><thead><tr>
    <% [['name','CSR'],['clinic','Clinic'],['outboundDials','Dials'],['answeredCalls','Answered'],['conversations','Conversations'],['validBookings','Bookings'],['answerRate','Answer rate'],['conversationRate','Conversation rate'],['conversationToBookingRate','Booking ratio'],['talkTimeSeconds','Talk time'],['talkTimeUtilization','Talk utilization'],['averageTalkTimePerConversation','Avg. talk / conversation'],['totalGapTimeSeconds','Gap time'],['averageSpeedToLeadSeconds','Avg. speed']].forEach(([key,label]) => { %><th><button type="button" data-sort="<%= key %>"><%= label %><i class="bi bi-arrow-down-up"></i></button></th><% }) %>
  </tr></thead><tbody data-table-body><% for (let i = 0; i < 5; i += 1) { %><tr class="skeleton-row"><td colspan="14"><span></span></td></tr><% } %></tbody></table></div>
  <div class="table-footer"><span data-table-count>Loading CSRs…</span><nav class="pagination-controls" data-pagination aria-label="CSR table pages"></nav></div>
</section>
