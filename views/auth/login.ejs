<section class="auth-card" aria-labelledby="login-heading">
  <div class="mobile-brand d-lg-none">
    <img class="brand-logo mobile-brand-logo" src="/brand-assets/67bbfaeacd6e05ec202385da_image%206-Photoroom%201.svg" alt="Pinpoint Scaling">
  </div>
  <div class="auth-card-heading">
    <span class="auth-login-icon"><i class="bi bi-person-lock" aria-hidden="true"></i></span>
    <div>
      <p class="eyebrow">Secure workspace</p>
      <h2 id="login-heading">Welcome back</h2>
      <p class="auth-subtitle">Sign in to access your performance dashboard.</p>
    </div>
  </div>

  <% if (typeof loggedOut !== 'undefined' && loggedOut) { %>
    <div class="alert alert-success" role="alert"><i class="bi bi-check-circle-fill me-2"></i>You have been logged out securely.</div>
  <% } %>

  <% if (errors.length) { %>
    <div class="alert alert-danger" role="alert">
      <% errors.forEach((error) => { %><div><i class="bi bi-exclamation-circle-fill me-2"></i><%= error.msg %></div><% }) %>
    </div>
  <% } %>

  <form action="/login" method="post" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="mb-3">
      <label class="form-label" for="email">Email address</label>
      <div class="input-icon-wrap">
        <i class="bi bi-envelope" aria-hidden="true"></i>
        <input class="form-control" id="email" name="email" type="email" value="<%= formData.email %>" autocomplete="username" maxlength="254" required autofocus>
      </div>
    </div>
    <div class="mb-4">
      <div class="auth-field-heading">
        <label class="form-label" for="password">Password</label>
        <span>Case sensitive</span>
      </div>
      <div class="input-icon-wrap password-wrap">
        <i class="bi bi-lock" aria-hidden="true"></i>
        <input class="form-control" id="password" name="password" type="password" autocomplete="current-password" required>
        <button class="password-toggle" type="button" data-password-toggle aria-label="Show password"><i class="bi bi-eye"></i></button>
      </div>
    </div>
    <button class="btn btn-primary w-100 login-button" type="submit"><span>Sign in to dashboard</span><i class="bi bi-arrow-right" aria-hidden="true"></i></button>
  </form>
  <div class="auth-security-row">
    <span><i class="bi bi-shield-lock" aria-hidden="true"></i> Encrypted session</span>
    <span><i class="bi bi-clock-history" aria-hidden="true"></i> Automatic timeout</span>
  </div>
</section>
